# ============================================================
# AADI MARKET — Environment Variables Example
# Copy to .env and fill values
# ============================================================

# Core app
NODE_ENV=development
AUTOMATION_MODE=simulation
AUTOMATION_STRICT_VALIDATION=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_BRAND_ID=brand_001
CONNECTOR_TIMESTAMP_SKEW_SECONDS=300

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# TLS workaround for local SSL interception only
# Remove in production
NODE_TLS_REJECT_UNAUTHORIZED=0

# LLM and media
GEMINI_API_KEY=your_gemini_key
GEMINI_API_KEY_IMAGE=your_gemini_image_key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_MODEL_FALLBACKS=gemini-embedding-2-preview,text-embedding-004,embedding-001
DEFAULT_LLM_BUDGET_USD_MONTHLY=10
GEMINI_INPUT_COST_PER_1M_TOKENS=0
GEMINI_OUTPUT_COST_PER_1M_TOKENS=0
FAL_KEY=your_fal_key

# Scraping and research (optional)
APIFY_API_TOKEN=your_apify_token
FIRECRAWL_API_KEY=your_firecrawl_key
PARENT_PLATFORM_BASE_URL=
PARENT_PLATFORM_API_KEY=
DEFAULT_SCRAPE_BUDGET_USD_MONTHLY=50
LLM_PROMPT_CACHE_TTL_SECONDS=300

# Postiz
POSTIZ_API_URL=http://localhost:4007/api/v1
NEXT_PUBLIC_POSTIZ_KEY=your_postiz_key
POSTIZ_API_KEY=your_postiz_key

# Security and scheduling
CRON_SECRET=your_cron_secret
INTERNAL_BOOTSTRAP_TOKEN=your_bootstrap_token

# Phase 1 credentials encryption
CREDENTIALS_MASTER_KEY=base64_32_byte_key
CREDENTIALS_KEY_ID=k1
# Optional override. If omitted, CREDENTIALS_MASTER_KEY is used.
CONNECTOR_SECRETS_ENCRYPTION_KEY=

# Inngest
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key
INNGEST_DEV=1

# Nonce replay protection (Upstash Redis)
CONNECTOR_NONCE_REDIS_URL=your_upstash_redis_url
CONNECTOR_NONCE_REDIS_TOKEN=your_upstash_redis_token

# Python worker integration
WORKER_BASE_URL=http://localhost:8000
WORKER_SHARED_SECRET=your_worker_shared_secret

# Meta Ads (optional)
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=act_your_ad_account_id
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v21.0

# Google Ads (optional)
GOOGLE_ADS_CLIENT_ID=your_google_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CUSTOMER_ID=your_customer_id
